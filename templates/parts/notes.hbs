<section
  class="tab {{tabs.notes.cssClass}} {{tabs.notes.id}} compact-tab-panel"
  data-tab="{{tabs.notes.id}}"
  data-group="{{tabs.notes.group}}"
>
  <div class="compact-tab-scroll compact-notes-scroll">
    <fieldset class="compact-notes-fieldset">
      <legend>{{localize tabs.notes.label}}</legend>
      {{formInput notes.field value=notes.value enriched=notes.enriched toggled=true}}
    </fieldset>

    {{#if (and showAttribution document.system.attribution.artist)}}
      <label class="artist-attribution compact-artist-attribution">{{localize 'DAGGERHEART.GENERAL.artistAttribution' artist=document.system.attribution.artist}}</label>
    {{/if}}
  </div>
</section>
