<div class="dhca-header__art-layer">
  {{#if document.img}}
    <div class="dhca-header__art">
      <img class="dhca-header__art-image" src="{{document.img}}" alt="" aria-hidden="true" />
    </div>
    {{#if compact.canEditImage}}
      <button
        type="button"
        class="dhca-header__art-edit"
        data-action="editImage"
        data-edit="img"
        data-tooltip-text="{{localize 'FILES.Edit'}}"
        aria-label="{{localize 'FILES.Edit'}}"
      >
        <i class="fa-solid fa-image"></i>
      </button>
    {{/if}}
  {{/if}}
</div>
