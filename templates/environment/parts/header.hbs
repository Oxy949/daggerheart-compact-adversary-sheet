<header class="environment-header-sheet dhca-section dhca-section--header dhca-header dhca-header--environment">
  <div class="dhca-header__adornment" aria-hidden="true">
    {{#if compact.identity.typeLabel}}
      <div class="dhca-header__ribbon">{{compact.identity.typeLabel}}</div>
    {{/if}}
    <div class="dhca-header__tier">{{source.system.tier}}</div>
  </div>

  <div class="dhca-header__identity">
    <h1
      class="input actor-name dhca-header__name"
      contenteditable="plaintext-only"
      data-property="name"
      placeholder="{{localize 'DAGGERHEART.GENERAL.actorName'}}"
    >{{source.name}}</h1>
  </div>

  {{#if description}}
    <div class="dhca-header__description">{{{description}}}</div>
  {{/if}}

  {{#if (and showAttribution document.system.attributionLabel)}}
    <div class="dhca-header__attribution">{{document.system.attributionLabel}}</div>
  {{/if}}

  <div class="dhca-header__stats dhca-header__stats--environment">
    <div class="dhca-summary__line">
      <span class="dhca-summary__label">{{localize 'DAGGERHEART.GENERAL.difficulty'}}:</span>
      <span class="dhca-summary__value">{{ifThen source.system.difficulty source.system.difficulty '-'}}</span>
    </div>
    {{#if compact.hasImpulses}}
      <div class="dhca-summary__line dhca-summary__line--impulses">
        <span class="dhca-summary__label">{{localize 'DAGGERHEART.ACTORS.Environment.FIELDS.impulses.label'}}:</span>
        <div class="dhca-summary__value dhca-rich-text dhca-rich-text--impulses">{{{source.system.impulses}}}</div>
      </div>
    {{/if}}
  </div>

  <div class="dhca-header__toolbar">
    <div class="dhca-tab-nav">
      <nav class="sheet-tabs tabs">
        <a
          class="{{tabs.features.cssClass}}"
          data-action="tab"
          data-group="{{tabs.features.group}}"
          data-tab="{{tabs.features.id}}"
          data-tooltip="{{localize tabs.features.label}}"
          aria-label="{{localize tabs.features.label}}"
        >
          <i class="fa-solid fa-list" inert></i>
        </a>
        <a
          class="{{tabs.potentialAdversaries.cssClass}}"
          data-action="tab"
          data-group="{{tabs.potentialAdversaries.group}}"
          data-tab="{{tabs.potentialAdversaries.id}}"
          data-tooltip="{{localize tabs.potentialAdversaries.label}}"
          aria-label="{{localize tabs.potentialAdversaries.label}}"
        >
          <i class="fa-solid fa-user-group" inert></i>
        </a>
        <a
          class="{{tabs.notes.cssClass}}"
          data-action="tab"
          data-group="{{tabs.notes.group}}"
          data-tab="{{tabs.notes.id}}"
          data-tooltip="{{localize tabs.notes.label}}"
          aria-label="{{localize tabs.notes.label}}"
        >
          <i class="fa-solid fa-note-sticky" inert></i>
        </a>
      </nav>
    </div>
    <div class="dhca-header-actions">
      <button type="button" data-action="openSettings" data-tooltip-text="{{localize 'DAGGERHEART.UI.Tooltip.openSheetSettings'}}">
        <i class="fa-solid fa-wrench"></i>
      </button>
    </div>
  </div>
</header>
